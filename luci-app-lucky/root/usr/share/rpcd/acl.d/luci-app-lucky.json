{
	"luci-app-lucky": {
		"description": "Grant access to lucky control and status",
		"read": {
			"ubus": {
				"luci-app-lucky": [ "get_status", "get_info" ],
				"file": [ "read" ],
				"uci": [ "get" ]
			},
			"uci": [ "lucky" ]
		},
		"write": {
			"ubus": {
				"luci-app-lucky": [ "set_config", "service" ],
				"uci": [ "set", "commit" ]
			},
			"uci": [ "lucky" ]
		}
	}
}
