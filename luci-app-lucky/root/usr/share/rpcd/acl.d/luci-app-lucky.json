{
	"luci-app-lucky": {
		"description": "Grant UCI and UBUS access for luci-app-lucky",
		"read": {
			"ubus": {
				"luci.lucky": [ "get_status", "get_info", "get_log" ]
			},
			"uci": [ "lucky" ],
			"file": {
				"/etc/init.d/lucky": [ "exec" ]
			}
		},
		"write": {
			"ubus": {
				"luci.lucky": [ "set_config", "service" ]
			},
			"uci": [ "lucky" ]
		}
	}
}